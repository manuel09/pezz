PORT=7001
HOST=127.0.0.1

# URL pubblico del server (dominio o IP, con protocollo).
# Deve essere raggiungibile dai client Stremio.
# PUBLIC_HOST=https://itahub.navidrome.dpdns.org

# Debrid: lascia vuoto per disabilitare il provider.
# Se entrambi sono valorizzati, RealDebrid ha la precedenza.
REALDEBRID_API_KEY=
TORBOX_API_KEY=

# Numero massimo di stream restituiti per richiesta
MAX_RESULTS=15

# Chiave per criptare la config utente nell'URL (AES-256-GCM).
# Se non impostata, ne viene generata una automaticamente e salvata
# in .encryption_key (persiste tra i restart).
# CONFIG_ENCRYPTION_KEY=

# Chiave per criptare i profili salvati in profiles_db.json (AES-256-GCM).
# Se non impostata, ne viene generata una automaticamente e salvata
# in .config_key (persiste tra i restart).
# PROFILES_ENCRYPTION_KEY=

# Segreto per le sessioni (login Stremio). Generane uno casuale.
# SESSION_SECRET=

# === WARP / Proxy per bypassare blocchi Cloudflare ===
# Abilita il routing delle richieste ai provider streaming attraverso
# un proxy SOCKS5 (es. Cloudflare WARP / wireproxy).
# Necessario per ADN (API + CDN devono condividere lo stesso IP WARP).
#
WARP_ENABLED=true
# Indirizzo del proxy SOCKS5 (default: socks5://127.0.0.1:1080)
WARP_PROXY=socks5://127.0.0.1:1080
# Host da ESCLUDERE dal proxy (API calls che non devono passare da WARP):
WARP_EXCLUDED_HOSTS=api.real-debrid.com,api.torbox.app,api.themoviedb.org,api.ani.zip,api.kitsu.io
# Host da INVIARE forzatamente al proxy (se vuoto, tutto passa dal proxy tranne excluded).
# vixsrc.to escluso (SC funziona diretto). sslip.io necessario per CDN ADN (IPv6).
WARP_PROXY_HOSTS=mostraguarda.stream,v.vidxgo.co,altadefinizionestreaming.com,sslip.io,supervideo.tv,supervideo.cc,vixcloud.co
#
# Wireproxy auto-setup (WARP via SOCKS5, no root required).
# Mette 'auto' per avvio automatico, 'off' per disabilitare.
WARP_CONFIG=auto

# Cookie di sessione per bypassare il Telegram gate di Altadefinizione.
# Se scade, prendine uno nuovo dal browser.
# ALTADEFINIZIONE_COOKIE=sid=...
